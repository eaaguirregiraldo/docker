{
  "family": "laravel-jwt-app-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::458470126884:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::458470126884:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "laravel-jwt-app",
      "image": "458470126884.dkr.ecr.us-east-1.amazonaws.com/laravel-jwt-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "APP_DEBUG", "value": "false" },
        { "name": "APP_URL", "value": "https://api.example.com" },
        { "name": "LOG_CHANNEL", "value": "stderr" },
        { "name": "DB_CONNECTION", "value": "mysql" },
        { "name": "DB_HOST", "value": "replace-with-real-db-host" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "DB_DATABASE", "value": "app" },
        { "name": "DB_USERNAME", "value": "app" },
        { "name": "DB_PASSWORD", "value": "replace-in-cd-with-secret" }
      ]
    }
  ]
}
